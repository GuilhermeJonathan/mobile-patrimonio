{
  "installCommand": "npm install",
  "buildCommand": "npx expo export --platform web",
  "outputDirectory": "dist",
  "framework": null,
  "routes": [
    {
      "src": "/_expo/static/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/_expo/static/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|map|html))",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/landing.html"
    },
    {
      "src": "/apresentacao",
      "dest": "/apresentacao.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
